.safe-nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 20;
  backdrop-filter: blur(22rpx);
  -webkit-backdrop-filter: blur(22rpx);
}

.safe-nav__row {
  position: absolute;
  left: 0;
  right: 0;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  column-gap: 18rpx;
}

.safe-nav__left,
.safe-nav__center,
.safe-nav__right {
  min-width: 0;
  display: flex;
  align-items: center;
}

.safe-nav__left {
  justify-content: flex-start;
}

.safe-nav__center {
  justify-content: center;
}

.safe-nav__right {
  justify-content: flex-end;
}
