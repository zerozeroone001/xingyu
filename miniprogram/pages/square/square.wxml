<view class="square-page">
  <scroll-view class="square-scroll" scroll-y enhanced lower-threshold="120" bindscrolltolower="onScrollToLower">
    <view class="square-content">
      <view class="search-row">
        <view wx:if="{{activeChannel === 'square'}}" class="search-bar" aria-label="搜索" bindtap="openSearch">
          <view class="search-icon"></view>
          <text class="search-placeholder">搜索诗句、诗人或话题</text>
        </view>
        <view wx:else class="search-bar room-search">
          <view class="search-icon"></view>
          <input class="room-search-input" value="{{roomSearchValue}}" placeholder="搜索令字、对局或诗友" bindinput="handleRoomSearchInput" />
          <view wx:if="{{roomSearchValue}}" class="search-clear" bindtap="clearRoomSearch">清</view>
        </view>
        <view class="publish-button" aria-label="发布" bindtap="composePost">{{activeChannel === 'square' ? '发布' : '发起'}}</view>
      </view>

      <view class="channel-tabs">
        <view class="channel-tab {{activeChannel === 'square' ? 'channel-tab--active' : ''}}" data-channel="square" bindtap="switchChannel">
          广场
        </view>
        <view class="channel-tab {{activeChannel === 'feihualing' ? 'channel-tab--active' : ''}}" data-channel="feihualing" bindtap="switchChannel">
          飞花令
        </view>
      </view>

      <block wx:if="{{activeChannel === 'square'}}">
        <view class="feed-list">
          <block wx:for="{{list}}" wx:key="id">
            <view class="topic-card" data-id="{{item.id}}" bindtap="openTopic">
              <view class="topic-head">
                <view class="topic-avatar topic-avatar--{{item.author.avatarTone}}">{{item.author.avatarText}}</view>
                <view class="topic-author">
                  <view class="topic-author-row">
                    <text class="topic-name">{{item.author.nickname}}</text>
                  </view>
                  <text class="topic-time">{{item.time}}</text>
                </view>
              </view>

              <view class="topic-tags" wx:if="{{item.tags.length}}">
                <block wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">
                  <text class="topic-tag">{{tag}}</text>
                </block>
              </view>

              <view class="topic-copy">
                <text class="topic-content">{{item.content}}</text>
              </view>

              <view wx:if="{{item.images.length}}" class="image-grid {{item.imageGridClass}}">
                <block wx:for="{{item.images}}" wx:for-item="image" wx:key="*this">
                  <image class="topic-image" src="{{image}}" mode="aspectFill" data-id="{{item.id}}" data-src="{{image}}" catchtap="previewTopicImage"></image>
                </block>
              </view>

              <view class="topic-actions">
                <view class="action-button {{item.isLiked ? 'action-button--active' : ''}}" data-id="{{item.id}}" catchtap="toggleTopicLike">
                  <image class="action-icon" src="/assets/icons/点赞.svg" mode="aspectFit"></image>
                  <text>{{item.likeCount}}</text>
                </view>
                <view class="action-button {{item.isFavorited ? 'action-button--active' : ''}}" data-id="{{item.id}}" catchtap="toggleTopicFavorite">
                  <image class="action-icon" src="/assets/icons/收藏.svg" mode="aspectFit"></image>
                  <text>{{item.favoriteCount}}</text>
                </view>
                <view class="action-button" data-id="{{item.id}}" catchtap="shareTopic">
                  <image class="action-icon" src="/assets/icons/分 享.svg" mode="aspectFit"></image>
                  <text>{{item.shareCount}}</text>
                </view>
                <view class="action-button action-button--comment" data-id="{{item.id}}" catchtap="openComments">
                  <image class="action-icon" src="/assets/icons/评论.svg" mode="aspectFit"></image>
                  <text>{{item.comments.length}}</text>
                </view>
              </view>

              <view wx:if="{{item.previewComments.length}}" class="comment-panel">
                <view class="comment-title-row">
                  <text class="comment-title">最新评论</text>
                  <text class="comment-more">最多显示 3 条</text>
                </view>
                <block wx:for="{{item.previewComments}}" wx:for-item="comment" wx:key="id">
                  <view class="comment-item">
                    <view class="comment-avatar comment-avatar--{{comment.avatarTone}}">{{comment.avatarText}}</view>
                    <view class="comment-body">
                      <view class="comment-meta">
                        <text class="comment-name">{{comment.nickname}}</text>
                        <text class="comment-time">{{comment.time}}</text>
                      </view>
                      <text class="comment-content">{{comment.content}}</text>
                      <view class="comment-actions">
                        <view class="comment-action {{comment.isLiked ? 'comment-action--active' : ''}}" data-topic-id="{{item.id}}" data-comment-id="{{comment.id}}" catchtap="toggleCommentLike">
                          <image class="comment-action-icon" src="/assets/icons/点赞.svg" mode="aspectFit"></image>
                          <text>{{comment.likeCount}}</text>
                        </view>
                        <view class="comment-action {{comment.isFavorited ? 'comment-action--active' : ''}}" data-topic-id="{{item.id}}" data-comment-id="{{comment.id}}" catchtap="toggleCommentFavorite">
                          <image class="comment-action-icon" src="/assets/icons/收藏.svg" mode="aspectFit"></image>
                          <text>{{comment.favoriteCount}}</text>
                        </view>
                      </view>
                    </view>
                  </view>
                </block>
              </view>
            </view>
          </block>

          <view wx:if="{{loading}}" class="feed-state">正在加载...</view>
          <view wx:elif="{{!hasMore && list.length}}" class="feed-state">没有更多内容了</view>
        </view>
      </block>

      <block wx:else>
        <view class="feihualing-panel">
          <view wx:if="{{featuredRoom}}" class="featured-room">
            <view class="featured-copy">
              <text class="featured-label">推荐诗令</text>
              <text class="featured-title">{{featuredRoom.title}}</text>
              <text class="featured-meta">令字「{{featuredRoom.keyword}}」 · {{featuredRoom.playerCount}}/{{featuredRoom.maxPlayers}} 人 · {{featuredRoom.statusText}}</text>
            </view>
            <view
              class="featured-button {{enteringRoomId === featuredRoom.id ? 'featured-button--loading' : ''}} {{!featuredRoom.canEnter ? 'featured-button--disabled' : ''}}"
              data-id="{{featuredRoom.id}}"
              data-role="{{featuredRoom.primaryRole}}"
              bindtap="enterRoom"
            >
              {{enteringRoomId === featuredRoom.id ? '进入中' : featuredRoom.primaryActionText}}
            </view>
          </view>

          <view class="lobby-summary">
            <view class="summary-item">
              <text class="summary-value">{{roomCount}}</text>
              <text class="summary-label">场对局</text>
            </view>
            <view class="summary-item">
              <text class="summary-value">{{watchableCount}}</text>
              <text class="summary-label">可观战</text>
            </view>
            <view class="summary-item">
              <text class="summary-value">{{recruitingCount}}</text>
              <text class="summary-label">可入局</text>
            </view>
            <view class="summary-item">
              <text class="summary-value">{{onlineCount}}</text>
              <text class="summary-label">在线诗友</text>
            </view>
          </view>

          <view class="room-filter-row">
            <view class="room-filter {{roomStatus === 'all' ? 'room-filter--active' : ''}}" data-status="all" bindtap="chooseRoomStatus">全部</view>
            <view class="room-filter {{roomStatus === 'recruiting' ? 'room-filter--active' : ''}}" data-status="recruiting" bindtap="chooseRoomStatus">可入局</view>
            <view class="room-filter {{roomStatus === 'watchable' ? 'room-filter--active' : ''}}" data-status="watchable" bindtap="chooseRoomStatus">可观战</view>
            <view class="room-filter {{roomStatus === 'active' ? 'room-filter--active' : ''}}" data-status="active" bindtap="chooseRoomStatus">进行中</view>
          </view>

          <scroll-view class="keyword-scroller" scroll-x enhanced show-scrollbar="{{false}}">
            <view class="keyword-track">
              <view class="keyword-chip {{roomKeyword === '' ? 'keyword-chip--active' : ''}}" data-keyword="" bindtap="chooseRoomKeyword">全部</view>
              <block wx:for="{{keywordOptions}}" wx:key="*this">
                <view class="keyword-chip {{roomKeyword === item ? 'keyword-chip--active' : ''}}" data-keyword="{{item}}" bindtap="chooseRoomKeyword">{{item}}</view>
              </block>
            </view>
          </scroll-view>

          <view class="room-section-head">
            <text class="room-section-title">诗令房间</text>
            <text class="room-section-note">{{filteredRooms.length}} 个匹配</text>
          </view>

          <view class="room-list">
            <block wx:for="{{filteredRooms}}" wx:key="id">
              <view class="room-card">
                <view class="room-main">
                  <view class="room-keyword">
                    <text class="room-keyword-label">关键字</text>
                    <text class="room-keyword-text">{{item.keyword}}</text>
                  </view>

                  <view class="room-info">
                    <view class="room-title-row">
                      <text class="room-title">{{item.title}}</text>
                      <text class="watch-tag {{item.canWatch ? 'watch-tag--on' : 'watch-tag--off'}}">
                        {{item.statusText}}
                      </text>
                    </view>

                    <view class="creator-row">
                      <view class="room-avatar room-avatar--{{item.creator.avatarTone}}">{{item.creator.avatarText}}</view>
                      <view class="creator-copy">
                        <text class="creator-name">{{item.creator.nickname}}</text>
                        <text class="creator-level">Lv.{{item.creator.level}} · {{item.creator.title}}</text>
                      </view>
                    </view>

                    <view class="room-meta">
                      <text>{{item.playerCount}}/{{item.maxPlayers}} 人</text>
                      <text>{{item.roundText}}</text>
                      <text>{{item.canWatch ? '可观战' : '不可观战'}}</text>
                    </view>
                    <view class="room-progress">
                      <view class="room-progress-bar" style="width: {{item.progress}}%;"></view>
                    </view>
                  </view>
                </view>

                <view class="room-actions {{item.canWatch && item.primaryRole !== 'spectator' ? 'room-actions--split' : ''}}">
                  <view
                    class="enter-button {{enteringRoomId === item.id && enteringRole !== 'spectator' ? 'enter-button--loading' : ''}} {{!item.canEnter ? 'enter-button--disabled' : ''}}"
                    data-id="{{item.id}}"
                    data-role="{{item.primaryRole}}"
                    bindtap="enterRoom"
                  >
                    {{enteringRoomId === item.id && enteringRole !== 'spectator' ? '进入中' : item.primaryActionText}}
                  </view>
                  <view
                    wx:if="{{item.canWatch && item.primaryRole !== 'spectator'}}"
                    class="watch-button {{enteringRoomId === item.id && enteringRole === 'spectator' ? 'watch-button--loading' : ''}}"
                    data-id="{{item.id}}"
                    data-role="spectator"
                    bindtap="enterRoom"
                  >
                    {{enteringRoomId === item.id && enteringRole === 'spectator' ? '进入中' : '观战'}}
                  </view>
                </view>
              </view>
            </block>
          </view>

          <view wx:if="{{roomLoading}}" class="feed-state">正在加载诗令...</view>
          <view wx:elif="{{!roomLoading && !filteredRooms.length}}" class="empty-room">
            <text class="empty-room-title">暂无匹配对局</text>
            <text class="empty-room-note">换个令字或清空筛选后再试。</text>
            <view class="empty-room-button" bindtap="resetRoomFilters">清空筛选</view>
          </view>
        </view>
      </block>
    </view>
  </scroll-view>

  <view wx:if="{{createDialogVisible}}" class="create-mask" bindtap="closeCreateDialog">
    <view class="create-sheet" catchtap="preventDialogClose">
      <view class="create-sheet-head">
        <view>
          <text class="create-title">发起飞花令</text>
          <text class="create-subtitle">设置令字与房间规则，诗友即可入局。</text>
        </view>
        <view class="create-close" aria-label="关闭" bindtap="closeCreateDialog">×</view>
      </view>

      <view class="create-field">
        <text class="create-label">令字</text>
        <scroll-view class="create-keyword-scroller" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="create-keyword-track">
            <block wx:for="{{keywordOptions}}" wx:key="*this">
              <view class="create-keyword {{createForm.keyword === item ? 'create-keyword--active' : ''}}" data-keyword="{{item}}" bindtap="chooseCreateKeyword">{{item}}</view>
            </block>
          </view>
        </scroll-view>
        <input class="create-input create-input--keyword" maxlength="2" value="{{createForm.keyword}}" placeholder="自定义令字" bindinput="handleCreateKeywordInput" />
      </view>

      <view class="create-field">
        <text class="create-label">对局名</text>
        <input class="create-input" maxlength="16" value="{{createForm.title}}" placeholder="如：月字雅集" bindinput="handleCreateTitleInput" />
      </view>

      <view class="create-field">
        <text class="create-label">人数</text>
        <view class="create-option-row">
          <block wx:for="{{maxPlayerOptions}}" wx:key="*this">
            <view class="create-option {{createForm.maxPlayers === item ? 'create-option--active' : ''}}" data-value="{{item}}" bindtap="chooseCreateMaxPlayers">{{item}} 人</view>
          </block>
        </view>
      </view>

      <view class="create-switch-row">
        <view>
          <text class="create-label">允许观战</text>
          <text class="create-help">开启后未入局诗友可旁观对局。</text>
        </view>
        <switch checked="{{createForm.canWatch}}" color="#2f704d" bindchange="toggleCreateWatch" />
      </view>

      <view
        class="create-submit {{createFormValid && !createSubmitting ? '' : 'create-submit--disabled'}}"
        bindtap="submitCreateRoom"
      >
        {{createSubmitting ? '发起中' : '发起对局'}}
      </view>
    </view>
  </view>
</view>
