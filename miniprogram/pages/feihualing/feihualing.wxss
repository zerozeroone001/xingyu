.feihualing-page {
  min-height: 100vh;
  background: #fbfaf5;
  color: #102236;
}

.feihualing-page::before {
  content: "";
  position: fixed;
  inset: 0;
  background-image: radial-gradient(rgba(43, 72, 60, 0.10) 1rpx, transparent 1rpx);
  background-size: 40rpx 40rpx;
  pointer-events: none;
}

.feihualing-scroll {
  position: relative;
  z-index: 1;
  height: 100vh;
}

.feihualing-content {
  padding: 34rpx 30rpx 190rpx;
}

.entry-page {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  padding: 34rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.entry-card {
  width: 100%;
  padding: 54rpx 32rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 12rpx 30rpx rgba(30, 44, 54, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.entry-spinner {
  width: 58rpx;
  height: 58rpx;
  border: 6rpx solid #dce8df;
  border-top-color: #2f704d;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

.entry-title {
  margin-top: 24rpx;
  color: #102236;
  font-size: 31rpx;
  font-weight: 800;
}

.entry-note {
  margin-top: 10rpx;
  color: #7b838b;
  font-size: 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.lobby-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.page-title {
  display: block;
  color: #102236;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.2;
}

.page-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6f747b;
  font-size: 26rpx;
  line-height: 1.35;
}

.create-button {
  flex-shrink: 0;
  width: 112rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: #2f704d;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.summary-row {
  margin-top: 30rpx;
  padding: 22rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 8rpx 22rpx rgba(30, 44, 54, 0.05);
  display: flex;
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.summary-value {
  color: #102236;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1;
}

.summary-label {
  color: #7b838b;
  font-size: 22rpx;
}

.room-list {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.room-card {
  padding: 24rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 10rpx 24rpx rgba(30, 44, 54, 0.07);
}

.room-main {
  display: flex;
  gap: 22rpx;
}

.keyword-badge {
  flex-shrink: 0;
  width: 128rpx;
  height: 156rpx;
  border: 4rpx double rgba(47, 112, 77, 0.32);
  border-radius: 8rpx;
  background:
    radial-gradient(circle at 70% 12%, rgba(225, 242, 205, 0.95), transparent 30%),
    #f4f2ec;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.keyword-label {
  color: #6f747b;
  font-size: 20rpx;
}

.keyword-text {
  margin-top: 12rpx;
  color: #102236;
  font-size: 72rpx;
  font-weight: 800;
  line-height: 1;
}

.room-info {
  flex: 1;
  min-width: 0;
}

.room-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.room-title {
  min-width: 0;
  color: #102236;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.watch-tag {
  flex-shrink: 0;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.watch-tag--on {
  background: #e7f4e8;
  color: #2f704d;
}

.watch-tag--off {
  background: #f1eee8;
  color: #8a6f54;
}

.creator-row {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.avatar {
  flex-shrink: 0;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar--sage {
  background: #d9e3df;
  color: #254a45;
}

.avatar--ink {
  background: #182231;
}

.avatar--green {
  background: #dfead7;
  color: #345b36;
}

.avatar--warm {
  background: #e8d8bf;
  color: #7a542e;
}

.creator-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.creator-name {
  color: #263442;
  font-size: 25rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.creator-level {
  color: #7b838b;
  font-size: 22rpx;
}

.room-meta {
  margin-top: 20rpx;
  color: #7b838b;
  font-size: 22rpx;
  display: flex;
  gap: 22rpx;
}

.room-actions {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 12rpx;
}

.room-actions--split {
  grid-template-columns: minmax(0, 1fr) 160rpx;
}

.enter-button,
.watch-button {
  min-width: 0;
  height: 76rpx;
  border-radius: 6rpx;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.enter-button {
  background: #102236;
  color: #fff;
}

.watch-button {
  border: 1rpx solid rgba(47, 112, 77, 0.24);
  background: #e7f4e8;
  color: #2f704d;
}

.enter-button--disabled {
  background: #aeb5b7;
}

.room-page {
  position: relative;
  z-index: 1;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f4efe5;
}

.room-header {
  flex-shrink: 0;
  min-height: 132rpx;
  padding: 26rpx 28rpx 22rpx;
  border-bottom: 1rpx solid rgba(42, 50, 58, 0.08);
  background: rgba(255, 250, 242, 0.96);
  box-shadow: 0 8rpx 22rpx rgba(30, 44, 54, 0.06);
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.room-back,
.room-end {
  flex-shrink: 0;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 28rpx;
  font-size: 23rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.room-back {
  background: #f0e6d5;
  color: #6d533a;
}

.room-end {
  border: 1rpx solid rgba(143, 79, 36, 0.18);
  background: #fff6ea;
  color: #8f4f24;
}

.room-heading {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.room-heading-title {
  color: #102236;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-heading-meta {
  color: #7b838b;
  font-size: 22rpx;
  line-height: 1.2;
}

.room-keyword-pill {
  flex-shrink: 0;
  width: 116rpx;
  height: 88rpx;
  border: 3rpx double rgba(47, 112, 77, 0.32);
  border-radius: 8rpx;
  background: #fffdf8;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.room-keyword-label {
  color: #7b838b;
  font-size: 19rpx;
  line-height: 1;
}

.room-keyword-value {
  margin-top: 8rpx;
  color: #2f704d;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1;
}

.waiting-stage {
  flex: 1;
  min-height: 0;
  padding: 30rpx 26rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.waiting-card {
  width: 100%;
  padding: 42rpx 30rpx 34rpx;
  border-radius: 8rpx;
  background: rgba(255, 250, 242, 0.96);
  box-shadow: 0 12rpx 30rpx rgba(30, 44, 54, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.waiting-keyword {
  width: 126rpx;
  height: 126rpx;
  border: 4rpx double rgba(47, 112, 77, 0.34);
  border-radius: 8rpx;
  background: #fffdf8;
  color: #2f704d;
  font-size: 70rpx;
  font-weight: 800;
  line-height: 126rpx;
  text-align: center;
}

.waiting-title {
  margin-top: 28rpx;
  color: #102236;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.28;
  text-align: center;
}

.waiting-hint {
  margin-top: 14rpx;
  color: #7b838b;
  font-size: 25rpx;
  line-height: 1.45;
  text-align: center;
}

.waiting-players {
  width: 100%;
  margin-top: 30rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.waiting-player {
  min-height: 112rpx;
  border: 1rpx dashed rgba(42, 50, 58, 0.16);
  border-radius: 8rpx;
  color: #8a8176;
  font-size: 23rpx;
  font-weight: 700;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.waiting-player--ready {
  border-style: solid;
  border-color: rgba(47, 112, 77, 0.2);
  background: #e7f4e8;
  color: #2f704d;
}

.waiting-player-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #fffdf8;
  color: inherit;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 44rpx;
  text-align: center;
}

.waiting-action {
  width: 100%;
  height: 78rpx;
  margin-top: 32rpx;
  border-radius: 6rpx;
  background: #2f704d;
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.waiting-action--ghost {
  border: 1rpx solid rgba(47, 112, 77, 0.22);
  background: #f7fbf5;
  color: #2f704d;
}

.dialog-window {
  flex: 1;
  min-height: 0;
  padding: 0 0 12rpx;
  box-sizing: border-box;
}

.dialog-list {
  min-height: 100%;
  padding: 30rpx 26rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-card {
  padding: 28rpx 26rpx;
  border-radius: 8rpx;
  background: #fffaf2;
  box-shadow: 0 8rpx 20rpx rgba(30, 44, 54, 0.06);
}

.result-title {
  display: block;
  color: #102236;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.2;
}

.result-summary {
  display: block;
  margin-top: 12rpx;
  color: #7b838b;
  font-size: 24rpx;
  line-height: 1.45;
}

.result-stats {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
}

.result-stat {
  min-height: 86rpx;
  border-radius: 8rpx;
  background: #f4efe5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.result-stat-value {
  color: #2f704d;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1;
}

.result-stat-label {
  color: #8a8176;
  font-size: 20rpx;
  line-height: 1;
}

.dialog-row {
  display: flex;
}

.dialog-row--system {
  justify-content: center;
}

.dialog-row--user {
  justify-content: flex-end;
}

.dialog-row--opponent {
  justify-content: flex-start;
}

.dialog-bubble {
  max-width: 78%;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 20rpx rgba(30, 44, 54, 0.06);
}

.dialog-bubble--system {
  max-width: 90%;
  padding: 18rpx 22rpx;
  background: rgba(255, 250, 242, 0.92);
  color: #6d533a;
}

.dialog-bubble--user {
  padding: 20rpx 22rpx 16rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(42, 50, 58, 0.08);
}

.dialog-bubble--opponent {
  padding: 20rpx 22rpx 16rpx;
  background: #eef6ee;
  border: 1rpx solid rgba(47, 112, 77, 0.14);
}

.dialog-bubble--correct {
  border-color: rgba(47, 112, 77, 0.22);
}

.dialog-bubble--wrong {
  border-color: rgba(143, 79, 36, 0.2);
}

.dialog-content {
  display: block;
  color: #102236;
  font-size: 29rpx;
  line-height: 1.58;
  white-space: pre-wrap;
  word-break: break-word;
}

.dialog-player {
  display: block;
  margin-bottom: 8rpx;
  color: #7b838b;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1;
}

.dialog-bubble--system .dialog-content {
  color: #6d533a;
  font-size: 24rpx;
}

.dialog-bubble--thinking .dialog-content {
  color: #7b838b;
}

.dialog-source {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(42, 50, 58, 0.08);
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
}

.dialog-status {
  flex-shrink: 0;
  height: 32rpx;
  padding: 0 12rpx;
  border-radius: 16rpx;
  background: #e7f4e8;
  color: #2f704d;
  font-size: 19rpx;
  font-weight: 800;
  line-height: 32rpx;
}

.dialog-bubble--wrong .dialog-status {
  background: #f0e6d5;
  color: #8f4f24;
}

.dialog-source-text {
  min-width: 0;
  color: #8a8176;
  font-size: 21rpx;
  line-height: 1.35;
  text-align: right;
}

.answer-bar {
  flex-shrink: 0;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(42, 50, 58, 0.08);
  background: rgba(255, 250, 242, 0.98);
  box-shadow: 0 -8rpx 22rpx rgba(30, 44, 54, 0.06);
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.answer-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(42, 50, 58, 0.08);
  border-radius: 38rpx;
  background: #fffdf8;
  color: #102236;
  font-size: 27rpx;
  box-sizing: border-box;
}

.answer-submit {
  flex-shrink: 0;
  width: 118rpx;
  height: 76rpx;
  border-radius: 38rpx;
  background: #2f704d;
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.answer-submit--disabled {
  background: #b8c4b8;
  color: rgba(255, 255, 255, 0.86);
}

.spectator-bar,
.end-bar {
  flex-shrink: 0;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(42, 50, 58, 0.08);
  background: rgba(255, 250, 242, 0.98);
  box-shadow: 0 -8rpx 22rpx rgba(30, 44, 54, 0.06);
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.spectator-bar {
  justify-content: space-between;
  color: #7b838b;
  font-size: 24rpx;
}

.spectator-action,
.end-action {
  flex-shrink: 0;
  min-width: 150rpx;
  height: 72rpx;
  padding: 0 22rpx;
  border-radius: 36rpx;
  background: #2f704d;
  color: #fff;
  font-size: 25rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.end-bar {
  justify-content: flex-end;
}

.end-action--ghost {
  border: 1rpx solid rgba(47, 112, 77, 0.22);
  background: #f7fbf5;
  color: #2f704d;
}
