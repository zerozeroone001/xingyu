.feihualing-page {
  min-height: 100vh;
  background: #fbfaf5;
  color: #102236;
}

.feihualing-page::before {
  content: "";
  position: fixed;
  inset: 0;
  background-image: radial-gradient(rgba(43, 72, 60, 0.10) 1rpx, transparent 1rpx);
  background-size: 40rpx 40rpx;
  pointer-events: none;
}

.feihualing-scroll {
  position: relative;
  z-index: 1;
  height: 100vh;
}

.feihualing-content {
  padding: 34rpx 30rpx 190rpx;
}

.lobby-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.page-title {
  display: block;
  color: #102236;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.2;
}

.page-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6f747b;
  font-size: 26rpx;
  line-height: 1.35;
}

.create-button {
  flex-shrink: 0;
  width: 112rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: #2f704d;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.summary-row {
  margin-top: 30rpx;
  padding: 22rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 8rpx 22rpx rgba(30, 44, 54, 0.05);
  display: flex;
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.summary-value {
  color: #102236;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1;
}

.summary-label {
  color: #7b838b;
  font-size: 22rpx;
}

.room-list {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.room-card {
  padding: 24rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 10rpx 24rpx rgba(30, 44, 54, 0.07);
}

.room-main {
  display: flex;
  gap: 22rpx;
}

.keyword-badge {
  flex-shrink: 0;
  width: 128rpx;
  height: 156rpx;
  border: 4rpx double rgba(47, 112, 77, 0.32);
  border-radius: 8rpx;
  background:
    radial-gradient(circle at 70% 12%, rgba(225, 242, 205, 0.95), transparent 30%),
    #f4f2ec;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.keyword-label {
  color: #6f747b;
  font-size: 20rpx;
}

.keyword-text {
  margin-top: 12rpx;
  color: #102236;
  font-size: 72rpx;
  font-weight: 800;
  line-height: 1;
}

.room-info {
  flex: 1;
  min-width: 0;
}

.room-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.room-title {
  min-width: 0;
  color: #102236;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.watch-tag {
  flex-shrink: 0;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.watch-tag--on {
  background: #e7f4e8;
  color: #2f704d;
}

.watch-tag--off {
  background: #f1eee8;
  color: #8a6f54;
}

.creator-row {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.avatar {
  flex-shrink: 0;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar--sage {
  background: #d9e3df;
  color: #254a45;
}

.avatar--ink {
  background: #182231;
}

.avatar--green {
  background: #dfead7;
  color: #345b36;
}

.avatar--warm {
  background: #e8d8bf;
  color: #7a542e;
}

.creator-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.creator-name {
  color: #263442;
  font-size: 25rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.creator-level {
  color: #7b838b;
  font-size: 22rpx;
}

.room-meta {
  margin-top: 20rpx;
  color: #7b838b;
  font-size: 22rpx;
  display: flex;
  gap: 22rpx;
}

.enter-button {
  width: 100%;
  height: 76rpx;
  margin-top: 24rpx;
  border-radius: 6rpx;
  background: #102236;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
