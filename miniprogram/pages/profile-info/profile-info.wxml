<view class="profile-info-page">
  <scroll-view class="profile-info-scroll" scroll-y enhanced>
    <view class="profile-info-content">
      <view class="profile-head">
        <view class="avatar">{{avatarText}}</view>
        <view class="profile-head-copy">
          <text class="profile-title">个人信息</text>
          <text class="profile-subtitle">Lv.{{level}} · 完善资料后诗友更容易认识你</text>
        </view>
      </view>

      <view class="form-section">
        <view class="form-row">
          <text class="field-label">昵称</text>
          <input value="{{form.nickname}}" data-field="nickname" placeholder="请输入昵称" bindinput="handleInput" />
        </view>
        <view class="form-row">
          <text class="field-label">称号</text>
          <input value="{{form.title}}" data-field="title" placeholder="例如：翰林学士" bindinput="handleInput" />
        </view>
        <view class="form-row">
          <text class="field-label">城市</text>
          <input value="{{form.city}}" data-field="city" placeholder="填写常驻城市" bindinput="handleInput" />
        </view>
        <view class="form-row form-row--textarea">
          <text class="field-label">简介</text>
          <textarea value="{{form.bio}}" data-field="bio" placeholder="写一段诗词偏好或个人介绍" maxlength="120" bindinput="handleInput"></textarea>
        </view>
      </view>

      <button class="save-button" loading="{{saving}}" bindtap="saveProfile">保存信息</button>
    </view>
  </scroll-view>
</view>
