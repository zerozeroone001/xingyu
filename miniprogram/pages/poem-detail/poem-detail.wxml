<view class="poem-detail-page">
  <safe-nav background="rgba(251, 248, 240, 0.9)" offset-top="8" side-gap="18" bindlayoutready="handleNavReady">
    <view slot="left" class="back-button" bindtap="goBack" aria-label="返回"></view>
  </safe-nav>

  <scroll-view class="detail-scroll" scroll-y enhanced>
    <view class="detail-content" style="padding-top: {{contentTop}}px;">
      <view class="poem-hero">
        <view class="hero-wash hero-wash--left"></view>
        <view class="hero-wash hero-wash--right"></view>
        <view class="hero-mountain hero-mountain--one"></view>
        <view class="hero-mountain hero-mountain--two"></view>
        <view class="hero-water"></view>

        <view class="poem-head">
          <text class="poem-kicker">{{poem.tags && poem.tags.length ? poem.tags[0] : '今日共读'}}</text>
          <text class="poem-title">{{poem.title}}</text>
          <text class="poem-author">— {{poem.author}} [{{poem.dynasty}}] —</text>
        </view>
      </view>

      <view class="poem-reading">
        <view class="poem-text {{isVertical ? 'poem-text--vertical' : ''}}">
          <text class="poem-content-text">{{poemContent}}</text>
        </view>
        <view class="layout-button poem-layout-button {{isVertical ? 'layout-button--active' : ''}}" bindtap="toggleLayout" aria-label="{{isVertical ? '切换横排' : '切换竖排'}}">
          <image class="layout-image" src="/assets/icons/排版.svg" mode="aspectFit"></image>
        </view>
      </view>

      <view class="action-bar">
        <view class="action-button {{isLiked ? 'action-button--active' : ''}}" bindtap="toggleLike">
          <image class="action-icon" src="/assets/icons/点赞.svg" mode="aspectFit"></image>
          <text>{{likeCount}}</text>
        </view>
        <view class="action-button {{isFavorite ? 'action-button--active' : ''}}" bindtap="toggleFavorite">
          <image class="action-icon" src="/assets/icons/收藏.svg" mode="aspectFit"></image>
          <text>{{favoriteCount}}</text>
        </view>
        <view class="action-button" bindtap="handleShareTap">
          <image class="action-icon" src="/assets/icons/分 享.svg" mode="aspectFit"></image>
          <text>{{shareCount}}</text>
        </view>
        <view class="note-button" bindtap="writeNote" aria-label="写笔记">
          <image class="note-image" src="/assets/icons/笔记.svg" mode="aspectFit"></image>
        </view>
      </view>

      <view class="poem-tags" wx:if="{{poem.tags && poem.tags.length}}">
        <block wx:for="{{poem.tags}}" wx:key="*this">
          <text>{{item}}</text>
        </block>
      </view>

      <view class="comments">
        <view class="comment-head">
          <text class="comment-title">评论</text>
          <view class="comment-tabs">
            <text class="active-filter">热评</text>
            <text>最新</text>
          </view>
        </view>

        <block wx:for="{{comments}}" wx:key="name">
          <view class="comment-item">
            <view class="comment-avatar">{{item.short}}</view>
            <view class="comment-body">
              <view class="comment-row">
                <text class="comment-name">{{item.name}}</text>
                <text class="comment-time">{{item.time}}</text>
              </view>
              <text class="comment-text">{{item.content}}</text>
            </view>
          </view>
        </block>
      </view>

      <view class="ink-landscape">
        <view class="ink-sun"></view>
        <view class="ink-mountain ink-mountain--one"></view>
        <view class="ink-mountain ink-mountain--two"></view>
        <view class="ink-mountain ink-mountain--three"></view>
        <view class="ink-boat"></view>
        <view class="ink-water"></view>
      </view>
    </view>
  </scroll-view>

  <view class="spark-button" bindtap="writeNote" aria-label="写笔记">
    <image class="spark-icon" src="/assets/icons/笔记.svg" mode="aspectFit"></image>
  </view>
</view>
