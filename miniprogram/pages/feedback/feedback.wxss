.feedback-page {
  min-height: 100vh;
  background: #fbfaf5;
  color: #102236;
}

.feedback-scroll {
  height: 100vh;
}

.feedback-content {
  padding: 34rpx 30rpx 120rpx;
}

.page-head {
  padding: 10rpx 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.page-title {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.page-intro {
  color: #687079;
  font-size: 24rpx;
  line-height: 1.45;
}

.category-row {
  display: flex;
  gap: 14rpx;
}

.category-chip {
  flex: 1;
  height: 64rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #687079;
  font-size: 23rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.category-chip--active {
  background: #2f704d;
  color: #fff;
}

.form-panel {
  margin-top: 24rpx;
  border-radius: 8rpx;
  background: #fff;
  box-shadow: 0 8rpx 22rpx rgba(30, 44, 54, 0.06);
}

.content-input {
  width: 100%;
  height: 300rpx;
  box-sizing: border-box;
  padding: 26rpx;
  color: #102236;
  font-size: 28rpx;
  line-height: 1.55;
}

.count-row {
  padding: 0 26rpx 22rpx;
  color: #8a8f96;
  font-size: 21rpx;
  text-align: right;
}

.contact-row {
  min-height: 96rpx;
  padding: 0 26rpx;
  border-top: 1rpx solid rgba(16, 34, 54, 0.08);
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.contact-row text {
  flex-shrink: 0;
  color: #687079;
  font-size: 25rpx;
}

.contact-row input {
  flex: 1;
  min-width: 0;
  height: 96rpx;
  color: #102236;
  font-size: 27rpx;
}

.submit-button {
  height: 88rpx;
  margin-top: 34rpx;
  border-radius: 8rpx;
  background: #2f704d;
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 88rpx;
}
