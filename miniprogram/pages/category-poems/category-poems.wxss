.category-poems-page {
  min-height: 100vh;
  background: #fbfaf5;
  color: #102236;
}

.category-poems-page::before {
  content: "";
  position: fixed;
  inset: 0;
  background-image: radial-gradient(rgba(43, 72, 60, 0.10) 1rpx, transparent 1rpx);
  background-size: 40rpx 40rpx;
  pointer-events: none;
}

.category-poems-scroll {
  position: relative;
  z-index: 1;
  height: 100vh;
}

.category-poems-content {
  padding: 30rpx 30rpx 120rpx;
}

.search-box {
  height: 72rpx;
  padding: 0 26rpx;
  border: 1rpx solid rgba(16, 34, 54, 0.08);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 8rpx 22rpx rgba(30, 44, 54, 0.05);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-icon {
  position: relative;
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
}

.search-icon::before {
  content: "";
  position: absolute;
  left: 3rpx;
  top: 2rpx;
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid #8a8f96;
  border-radius: 50%;
}

.search-icon::after {
  content: "";
  position: absolute;
  right: 2rpx;
  bottom: 5rpx;
  width: 17rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: #8a8f96;
  transform: rotate(45deg);
}

.search-box input {
  flex: 1;
  min-width: 0;
  height: 100%;
  color: #102236;
  font-size: 28rpx;
}

.clear-button {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(16, 34, 54, 0.08);
  color: rgba(16, 34, 54, 0.56);
  font-size: 32rpx;
  line-height: 42rpx;
  text-align: center;
}

.poem-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.poem-item {
  width: 100%;
  box-sizing: border-box;
  margin: 0;
  min-height: 210rpx;
  padding: 26rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 8rpx 22rpx rgba(30, 44, 54, 0.06);
  display: flex;
  align-items: stretch;
  justify-content: flex-start;
  text-align: left;
  line-height: 1.35;
}

.poem-main {
  width: 100%;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.poem-title {
  width: 100%;
  color: #102236;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.25;
  text-align: left;
}

.poem-meta {
  width: 100%;
  margin-top: 8rpx;
  color: #718078;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.35;
  text-align: left;
}

.poem-recommend {
  width: 100%;
  margin-top: 16rpx;
  color: #3d454d;
  font-size: 26rpx;
  line-height: 1.55;
  text-align: left;
}

.poem-tags {
  width: 100%;
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  gap: 10rpx;
}

.poem-tags text {
  height: 36rpx;
  padding: 0 14rpx;
  border-radius: 18rpx;
  background: rgba(227, 218, 198, 0.38);
  color: rgba(96, 75, 51, 0.78);
  font-size: 19rpx;
  line-height: 36rpx;
}

.poem-stats {
  width: 100%;
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-start;
  gap: 28rpx;
  color: #6f747b;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.3;
}

.empty-panel {
  min-height: 260rpx;
  margin-top: 24rpx;
  padding: 60rpx 40rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.66);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.empty-title {
  color: #102236;
  font-size: 30rpx;
  font-weight: 800;
}
