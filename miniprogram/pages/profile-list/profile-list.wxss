.profile-list-page {
  min-height: 100vh;
  background: #fbfaf5;
  color: #102236;
}

.profile-list-scroll {
  height: 100vh;
}

.profile-list-content {
  padding: 34rpx 30rpx 120rpx;
}

.page-head {
  padding: 10rpx 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.page-title {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.page-intro {
  color: #687079;
  font-size: 24rpx;
  line-height: 1.45;
}

.item-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.list-item {
  min-height: 156rpx;
  padding: 24rpx;
  border-radius: 8rpx;
  background: #fff;
  box-shadow: 0 8rpx 22rpx rgba(30, 44, 54, 0.06);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  flex-shrink: 0;
  width: 78rpx;
  height: 78rpx;
  border-radius: 12rpx;
  background: #233235;
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.item-title {
  flex: 1;
  min-width: 0;
  color: #102236;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.28;
}

.item-badge {
  flex-shrink: 0;
  height: 36rpx;
  padding: 0 14rpx;
  border-radius: 18rpx;
  background: #eaf8eb;
  color: #2f704d;
  font-size: 19rpx;
  line-height: 36rpx;
}

.item-subtitle {
  margin-top: 8rpx;
  color: #718078;
  font-size: 22rpx;
  line-height: 1.35;
}

.item-content {
  margin-top: 14rpx;
  color: #3d454d;
  font-size: 25rpx;
  line-height: 1.55;
}

.item-foot {
  margin-top: 14rpx;
  color: #8a8f96;
  font-size: 21rpx;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.item-stats {
  flex-shrink: 0;
  display: flex;
  gap: 18rpx;
}

.arrow {
  color: #606872;
  font-size: 42rpx;
  line-height: 1;
}

.empty-panel {
  min-height: 280rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #687079;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
