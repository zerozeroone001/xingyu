.login-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #eef4ee;
  color: #102236;
}

.mountain-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, #f8f8ed 0%, #d8e8df 45%, #f4f4ed 100%);
}

.peak {
  position: absolute;
  background: linear-gradient(145deg, rgba(47, 92, 89, 0.62), rgba(222, 235, 225, 0.28));
  transform: rotate(45deg);
}

.peak--main {
  left: 210rpx;
  top: 46rpx;
  width: 440rpx;
  height: 620rpx;
  border-radius: 120rpx 260rpx 110rpx 260rpx;
}

.peak--left {
  left: -130rpx;
  top: 250rpx;
  width: 330rpx;
  height: 430rpx;
  opacity: 0.52;
}

.peak--right {
  right: -150rpx;
  top: 200rpx;
  width: 330rpx;
  height: 470rpx;
  opacity: 0.48;
}

.lake {
  position: absolute;
  left: 50%;
  bottom: 128rpx;
  width: 520rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.42);
  transform: translateX(-50%);
}

.login-title {
  position: relative;
  z-index: 1;
  padding-top: 260rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand {
  font-size: 60rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 24rpx;
  color: rgba(16, 34, 54, 0.64);
  font-size: 34rpx;
  font-weight: 700;
}

.title-line {
  width: 88rpx;
  height: 2rpx;
  margin-top: 38rpx;
  background: rgba(16, 34, 54, 0.18);
}

.login-card {
  position: relative;
  z-index: 1;
  margin: 150rpx 36rpx 0;
  padding: 52rpx 48rpx 46rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 20rpx 54rpx rgba(33, 52, 46, 0.14);
}

.login-copy {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.login-heading {
  color: #102236;
  font-size: 34rpx;
  font-weight: 800;
}

.login-desc {
  max-width: 520rpx;
  margin-top: 18rpx;
  color: #69727a;
  font-size: 25rpx;
  line-height: 1.7;
}

.wechat-button {
  height: 90rpx;
  margin-top: 44rpx;
  border-radius: 12rpx;
  background: #347348;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 28rpx rgba(52, 115, 72, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.wechat-icon {
  position: relative;
  width: 42rpx;
  height: 34rpx;
}

.wechat-icon::before,
.wechat-icon::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  background: #fff;
}

.wechat-icon::before {
  left: 0;
  top: 4rpx;
  width: 30rpx;
  height: 24rpx;
}

.wechat-icon::after {
  right: 0;
  top: 0;
  width: 28rpx;
  height: 22rpx;
  opacity: 0.92;
}

.wechat-dot {
  position: absolute;
  z-index: 1;
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: #347348;
}

.wechat-dot--left {
  left: 9rpx;
  top: 13rpx;
}

.wechat-dot--right {
  left: 20rpx;
  top: 13rpx;
}

.guest-button {
  height: 74rpx;
  margin-top: 22rpx;
  color: #52606a;
  font-size: 27rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.agreement {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 88rpx;
  z-index: 1;
  color: #6e747c;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  justify-content: center;
  gap: 10rpx;
}

.link {
  color: #2f704d;
  text-decoration: underline;
}
