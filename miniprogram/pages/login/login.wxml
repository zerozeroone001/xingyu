<view class="login-page">
  <view class="mountain-bg">
    <view class="peak peak--main"></view>
    <view class="peak peak--left"></view>
    <view class="peak peak--right"></view>
    <view class="lake"></view>
  </view>

  <view class="login-title">
    <text class="brand">山水诗境</text>
    <text class="subtitle">开启您的诗意之旅</text>
    <view class="title-line"></view>
  </view>

  <view class="login-card">
    <view class="login-copy">
      <text class="login-heading">微信授权登录</text>
      <text class="login-desc">授权后同步头像昵称，用于展示个人主页、收藏与创作记录。</text>
    </view>

    <view class="wechat-button" bindtap="handleWxLogin">
      <view class="wechat-icon">
        <view class="wechat-dot wechat-dot--left"></view>
        <view class="wechat-dot wechat-dot--right"></view>
      </view>
      <text>微信授权登录</text>
    </view>

    <view class="guest-button" bindtap="handleGuestEnter">游客浏览</view>
  </view>

  <view class="agreement">
    <text>登录即代表您同意</text>
    <text class="link">服务协议</text>
    <text>与</text>
    <text class="link">隐私政策</text>
  </view>
</view>
