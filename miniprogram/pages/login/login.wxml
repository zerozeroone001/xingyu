<view class="login-page">
  <view class="mountain-bg">
    <view class="peak peak--main"></view>
    <view class="peak peak--left"></view>
    <view class="peak peak--right"></view>
    <view class="lake"></view>
  </view>

  <view class="login-title">
    <text class="brand">山水诗境</text>
    <text class="subtitle">开启您的诗意之旅</text>
    <view class="title-line"></view>
  </view>

  <view class="login-card">
    <view class="form-row">
      <text class="label">手机号码</text>
      <view class="input-line">
        <text class="prefix">+86</text>
        <input value="{{phone}}" placeholder="请输入手机号" type="number" bindinput="handlePhoneInput" />
      </view>
    </view>

    <view class="form-row">
      <text class="label">验证码</text>
      <view class="input-line">
        <input value="{{code}}" placeholder="六位验证码" type="number" bindinput="handleCodeInput" />
        <view class="code-button" bindtap="getCode">获取验证码</view>
      </view>
    </view>

    <view class="login-button" bindtap="handleGuestEnter">立即登录</view>

    <view class="divider">
      <view></view>
      <text>或者通过</text>
      <view></view>
    </view>

    <view class="wechat-button" bindtap="handleWxLogin">
      <view class="wechat-dot"></view>
      <text>微信一键登录</text>
    </view>
  </view>

  <view class="agreement">
    <text>登录即代表您同意</text>
    <text class="link">服务协议</text>
    <text>与</text>
    <text class="link">隐私政策</text>
  </view>
</view>
