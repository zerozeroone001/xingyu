.home-page {
  min-height: 100vh;
  background: #d5eef4;
  color: #1c3244;
  overflow: hidden;
}

.home-nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 20;
  background: transparent;
  pointer-events: none;
}

.home-hero {
  position: relative;
  min-height: 100vh;
  padding-top: 188rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 210rpx);
  background:
    linear-gradient(180deg, rgba(124, 210, 232, 0.88) 0%, rgba(201, 237, 245, 0.78) 20%, rgba(243, 249, 244, 0.56) 48%, rgba(207, 229, 218, 0.76) 100%),
    linear-gradient(180deg, #aee2ef 0%, #f2f8ee 54%, #c8e2d9 100%);
  overflow: hidden;
}

.home-hero::before {
  content: "";
  position: absolute;
  left: -16rpx;
  right: -16rpx;
  bottom: -30rpx;
  height: 390rpx;
  background:
    radial-gradient(ellipse at 52% 0%, rgba(255, 252, 238, 0.92) 0%, rgba(255, 252, 238, 0.42) 35%, rgba(255, 252, 238, 0) 70%),
    repeating-linear-gradient(176deg, rgba(255, 255, 255, 0.28) 0 8rpx, rgba(126, 164, 158, 0.10) 10rpx 14rpx, rgba(255, 255, 255, 0) 18rpx 32rpx);
  opacity: 0.78;
}

.home-hero::after {
  content: "";
  position: absolute;
  left: -60rpx;
  right: -60rpx;
  top: 470rpx;
  height: 410rpx;
  background:
    radial-gradient(ellipse at 16% 74%, rgba(89, 139, 120, 0.42) 0%, rgba(89, 139, 120, 0.14) 18%, rgba(89, 139, 120, 0) 34%),
    radial-gradient(ellipse at 76% 44%, rgba(68, 116, 100, 0.58) 0%, rgba(68, 116, 100, 0.22) 24%, rgba(68, 116, 100, 0) 42%),
    linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(244, 250, 244, 0.62) 70%, rgba(225, 238, 229, 0.86) 100%);
  filter: blur(4rpx);
  opacity: 0.74;
}

.wash {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.46);
  filter: blur(10rpx);
}

.wash--left {
  left: -74rpx;
  top: 78rpx;
  width: 230rpx;
  height: 96rpx;
}

.wash--right {
  right: -82rpx;
  top: 236rpx;
  width: 230rpx;
  height: 118rpx;
}

.mountain {
  position: absolute;
  z-index: 1;
  opacity: 0.54;
  background: linear-gradient(155deg, rgba(60, 119, 97, 0.82), rgba(225, 240, 229, 0.26));
  transform: rotate(45deg);
}

.mountain--left {
  left: -122rpx;
  top: 435rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 46rpx 136rpx 56rpx 136rpx;
}

.mountain--center {
  left: 98rpx;
  top: 372rpx;
  width: 335rpx;
  height: 335rpx;
  border-radius: 62rpx 178rpx 70rpx 178rpx;
  opacity: 0.36;
}

.mountain--right {
  right: -94rpx;
  top: 330rpx;
  width: 380rpx;
  height: 380rpx;
  border-radius: 76rpx 198rpx 78rpx 198rpx;
}

.lake-glow {
  position: absolute;
  z-index: 1;
  left: 50%;
  top: 650rpx;
  width: 470rpx;
  height: 245rpx;
  border-radius: 50%;
  background: rgba(255, 252, 236, 0.68);
  transform: translateX(-50%);
  filter: blur(16rpx);
}

.water-lines {
  position: absolute;
  z-index: 1;
  left: 0;
  right: 0;
  bottom: 58rpx;
  height: 360rpx;
  opacity: 0.64;
}

.water-line {
  position: absolute;
  left: 50%;
  height: 3rpx;
  border-radius: 999rpx;
  background: rgba(80, 130, 123, 0.14);
  transform: translateX(-50%);
}

.water-line--one {
  top: 46rpx;
  width: 360rpx;
}

.water-line--two {
  top: 112rpx;
  width: 560rpx;
}

.water-line--three {
  top: 206rpx;
  width: 440rpx;
}

.water-line--four {
  top: 290rpx;
  width: 660rpx;
}

.poem-heading {
  position: relative;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.poem-content {
  opacity: 1;
  transform: translateX(0);
  transition: opacity 170ms ease, transform 170ms ease;
  will-change: opacity, transform;
}

.poem-content--exit-left,
.poem-content--enter-left {
  opacity: 0;
  transform: translateX(-36rpx);
}

.poem-content--exit-right,
.poem-content--enter-right {
  opacity: 0;
  transform: translateX(36rpx);
}

.poem-label {
  min-width: 132rpx;
  height: 42rpx;
  padding: 0 18rpx;
  border-radius: 7rpx;
  background: rgba(199, 229, 202, 0.48);
  color: rgba(61, 117, 92, 0.86);
  font-size: 22rpx;
  font-weight: 500;
  line-height: 42rpx;
  text-align: center;
}

.poem-title {
  margin-top: 64rpx;
  color: #1b3042;
  font-size: 54rpx;
  font-weight: 800;
  line-height: 1;
}

.poem-author {
  margin-top: 38rpx;
  color: rgba(72, 83, 92, 0.68);
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1;
}

.poem-switcher {
  position: relative;
  z-index: 3;
  width: 690rpx;
  margin: 78rpx auto 0;
}

.poem-panel {
  position: relative;
  z-index: 3;
  width: 590rpx;
  min-height: 330rpx;
  margin: 0 auto;
  padding: 76rpx 56rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.58);
  border-radius: 70rpx;
  background: rgba(241, 247, 237, 0.48);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.52), 0 22rpx 52rpx rgba(65, 98, 92, 0.10);
  backdrop-filter: blur(28rpx);
  -webkit-backdrop-filter: blur(28rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.poem-line {
  display: block;
  max-width: 100%;
  color: rgba(54, 75, 72, 0.62);
  font-size: 46rpx;
  font-weight: 500;
  line-height: 1.7;
  text-align: center;
  word-break: break-all;
  overflow-wrap: break-word;
}

.poem-tools {
  position: relative;
  z-index: 4;
  width: 456rpx;
  margin: 34rpx auto 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tool-button {
  width: 108rpx;
  height: 82rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 0;
  color: rgba(55, 74, 81, 0.62);
  font-size: 22rpx;
  line-height: 1;
}

.tool-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.72;
}

.tool-button--active .tool-icon {
  opacity: 1;
}

.tool-count {
  min-width: 54rpx;
  color: rgba(54, 75, 72, 0.64);
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1;
  text-align: center;
}
