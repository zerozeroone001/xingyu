.publish-page {
  min-height: 100vh;
  background: #f8f3ea;
  color: #18283a;
}

.publish-scroll {
  height: 100vh;
}

.publish-content {
  padding: 22rpx 30rpx 180rpx;
}

.form-section {
  margin-top: 30rpx;
  padding: 28rpx 24rpx;
  border: 1rpx solid rgba(42, 50, 58, 0.07);
  border-radius: 8rpx;
  background: rgba(255, 252, 246, 0.96);
  box-shadow: 0 12rpx 28rpx rgba(53, 41, 31, 0.06);
}

.form-section--first {
  margin-top: 0;
}

.field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.field-label {
  color: #1d2d3d;
  font-size: 26rpx;
  font-weight: 800;
}

.field-hint {
  color: #968877;
  font-size: 22rpx;
}

.tag-list {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-chip {
  flex-shrink: 0;
  height: 52rpx;
  padding: 0 20rpx;
  border-radius: 26rpx;
  background: #f1e8db;
  color: #745f48;
  font-size: 23rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tag-chip--active {
  background: #2f704d;
  color: #fff;
}

.custom-tag-row {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.custom-tag-input {
  flex: 1;
  min-width: 0;
  height: 68rpx;
  padding: 0 22rpx;
  border-radius: 34rpx;
  background: #f6efe4;
  color: #18283a;
  font-size: 26rpx;
}

.add-tag-button {
  flex-shrink: 0;
  width: 104rpx;
  height: 68rpx;
  border-radius: 34rpx;
  background: #18283a;
  color: #fff;
  font-size: 25rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.content-input {
  width: 100%;
  min-height: 300rpx;
  margin-top: 20rpx;
  color: #334150;
  font-size: 29rpx;
  line-height: 1.65;
}

.image-picker {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  align-items: flex-start;
}

.picked-image-wrap,
.add-image {
  flex: 0 0 calc((100% - 20rpx) / 3);
  width: calc((100% - 20rpx) / 3);
  position: relative;
  height: 212rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: #efe5d6;
}

.image-picker--count-0 .add-image {
  flex-basis: 100%;
  width: 100%;
  height: 220rpx;
}

.image-picker--count-1 .picked-image-wrap,
.image-picker--count-1 .add-image {
  flex-basis: 100%;
  width: 100%;
  height: 392rpx;
}

.image-picker--count-2 .picked-image-wrap,
.image-picker--count-2 .add-image,
.image-picker--count-4 .picked-image-wrap,
.image-picker--count-4 .add-image {
  flex-basis: calc((100% - 10rpx) / 2);
  width: calc((100% - 10rpx) / 2);
  height: 316rpx;
}

.image-picker--count-3 .picked-image-wrap,
.image-picker--count-3 .add-image,
.image-picker--count-5 .picked-image-wrap,
.image-picker--count-5 .add-image,
.image-picker--count-6 .picked-image-wrap,
.image-picker--count-6 .add-image,
.image-picker--count-7 .picked-image-wrap,
.image-picker--count-7 .add-image,
.image-picker--count-8 .picked-image-wrap,
.image-picker--count-8 .add-image,
.image-picker--count-9 .picked-image-wrap {
  flex-basis: calc((100% - 20rpx) / 3);
  width: calc((100% - 20rpx) / 3);
  height: 212rpx;
}

.picked-image {
  width: 100%;
  height: 100%;
  display: block;
}

.remove-image {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  z-index: 3;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  color: #d9352a;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 42rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(74, 28, 22, 0.18);
}

.add-image {
  border: 2rpx dashed rgba(47, 112, 77, 0.34);
  color: #2f704d;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.add-mark {
  font-size: 54rpx;
  line-height: 1;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 18rpx 30rpx calc(env(safe-area-inset-bottom) + 18rpx);
  border-top: 1rpx solid rgba(42, 50, 58, 0.08);
  background: rgba(248, 243, 234, 0.96);
  display: flex;
  gap: 18rpx;
}

.cancel-button,
.submit-button {
  height: 82rpx;
  border-radius: 41rpx;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-button {
  flex: 0 0 172rpx;
  background: #efe5d6;
  color: #6f6253;
}

.submit-button {
  flex: 1;
  background: #2f704d;
  color: #fff;
  box-shadow: 0 12rpx 24rpx rgba(47, 112, 77, 0.18);
}

.submit-button--loading {
  opacity: 0.78;
}
